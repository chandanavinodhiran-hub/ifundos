// iFundOS — Prisma Schema
// Core data models for the Intelligent Fund Operating System
// Database: PostgreSQL (Neon serverless)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ORGANIZATION — Contractors, Fund bodies, Ministries, Auditors
// ============================================================
model Organization {
  id                    String   @id @default(cuid())
  name                  String
  type                  String   // CONTRACTOR | FUND | MINISTRY | AUDITOR
  registrationNumber    String?  @unique
  capitalization        Float?
  trustTier             String   @default("T0") // T0–T4
  status                String   @default("ACTIVE") // ACTIVE | SUSPENDED
  preQualificationScore Float?
  businessCategories    String?  // JSON array of categories
  certifications        String?  // JSON array of certifications
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users        User[]
  applications Application[]
  contracts    Contract[]
}

// ============================================================
// USER — Authenticated users with role-based access
// ============================================================
model User {
  id             String   @id @default(cuid())
  organizationId String?
  email          String   @unique
  name           String
  passwordHash   String
  role           String   // CONTRACTOR | FUND_MANAGER | ADMIN | AUDITOR
  mfaEnabled     Boolean  @default(false)
  clearanceLevel Int      @default(1)
  status         String   @default("ACTIVE") // ACTIVE | SUSPENDED | PENDING
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization             Organization?             @relation(fields: [organizationId], references: [id])
  reviews                  Review[]
  auditEvents              AuditEvent[]
  boostActions             BoostAction[]
  questionnaireEvaluations QuestionnaireEvaluation[]
}

// ============================================================
// PROGRAM — Funding programs under the Saudi Green Initiative
// ============================================================
model Program {
  id               String   @id @default(cuid())
  name             String
  description      String?
  budgetTotal      Float
  budgetAllocated  Float    @default(0)
  budgetDisbursed  Float    @default(0)
  sgiTargets       String?  // JSON string — SGI alignment targets
  status           String   @default("ACTIVE") // ACTIVE | CLOSED | DRAFT
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rfps      RFP[]
  contracts Contract[]
}

// ============================================================
// RFP — Requests for Proposals issued under a Program
// ============================================================
model RFP {
  id                    String   @id @default(cuid())
  programId             String
  title                 String
  description           String?
  eligibilityCriteria   String?  // JSON string
  scoringRubric         String?  // JSON string
  evidenceRequirements  String?  // JSON string
  questionnaireConfig   String?  // JSON string — custom questionnaire questions
  deadline              DateTime?
  status                String   @default("DRAFT") // DRAFT | OPEN | CLOSED | AWARDED
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  program                Program                 @relation(fields: [programId], references: [id])
  applications           Application[]
  questionnaireQuestions  QuestionnaireQuestion[]
}

// ============================================================
// APPLICATION — Contractor proposals submitted against an RFP
// ============================================================
model Application {
  id                        String    @id @default(cuid())
  rfpId                     String
  organizationId            String
  proposalData              String?   // JSON string — full multi-step application data
  proposedBudget            Float     @default(0)
  compositeScore            Float?
  dimensionScores           String?   // JSON string — {procurement, vision, viability, impact}
  confidenceLevels          String?   // JSON string
  aiFindings                String?   // JSON string — findings from AI scoring
  status                    String    @default("DRAFT")
  // Status flow: DRAFT → SUBMITTED → SCORING → IN_REVIEW → SHORTLISTED → QUESTIONNAIRE_PENDING → QUESTIONNAIRE_SUBMITTED → APPROVED | REJECTED
  shortlistedAt             DateTime?
  questionnaireStatus       String    @default("NOT_SENT") // NOT_SENT | PENDING | SUBMITTED
  questionnaireSentAt       DateTime?
  questionnaireSubmittedAt  DateTime?
  submittedAt               DateTime?
  rejectionReason           String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  rfp                      RFP                      @relation(fields: [rfpId], references: [id])
  organization             Organization             @relation(fields: [organizationId], references: [id])
  decisionPacket           DecisionPacket?
  reviews                  Review[]
  contract                 Contract?
  questionnaireResponses   QuestionnaireResponse[]
  questionnaireEvaluations QuestionnaireEvaluation[]
}

// ============================================================
// DECISION PACKET — AI-generated analysis for committee review
// ============================================================
model DecisionPacket {
  id                String   @id @default(cuid())
  applicationId     String   @unique
  narrative         String?
  recommendation    String?  // RECOMMEND | RECOMMEND_WITH_CONDITIONS | DO_NOT_RECOMMEND
  executiveSummary  String?
  strengths         String?  // JSON array
  risks             String?  // JSON array (renamed from keyRisks)
  questionsForContractor String? // JSON array
  impactAssessment  String?
  scoringEvidence   String?  // JSON string
  createdByModel    String?  // e.g. "claude-sonnet-4-20250514" or "mock"
  createdAt         DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
}

// ============================================================
// QUESTIONNAIRE QUESTION — Custom questions attached to an RFP
// ============================================================
model QuestionnaireQuestion {
  id           String   @id @default(cuid())
  rfpId        String
  questionText String
  questionType String   // SHORT_ANSWER | LONG_ANSWER | MULTIPLE_CHOICE | FILE_UPLOAD
  isRequired   Boolean  @default(true)
  sortOrder    Int      @default(0)
  options      String?  // JSON array for multiple choice options
  createdAt    DateTime @default(now())

  rfp       RFP                      @relation(fields: [rfpId], references: [id])
  responses QuestionnaireResponse[]
  evaluations QuestionnaireEvaluation[]
}

// ============================================================
// QUESTIONNAIRE RESPONSE — Contractor answers to questionnaire
// ============================================================
model QuestionnaireResponse {
  id           String    @id @default(cuid())
  applicationId String
  questionId   String
  responseText String?
  filePath     String?   // For file upload questions
  submittedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  application Application           @relation(fields: [applicationId], references: [id])
  question    QuestionnaireQuestion  @relation(fields: [questionId], references: [id])
}

// ============================================================
// QUESTIONNAIRE EVALUATION — Fund manager's internal notes on responses
// ============================================================
model QuestionnaireEvaluation {
  id             String   @id @default(cuid())
  applicationId  String
  questionId     String
  evaluatorId    String
  internalNotes  String?
  internalScore  Int?     // 0-10
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  application Application           @relation(fields: [applicationId], references: [id])
  question    QuestionnaireQuestion  @relation(fields: [questionId], references: [id])
  evaluator   User                   @relation(fields: [evaluatorId], references: [id])
}

// ============================================================
// REVIEW — Committee member votes on applications
// ============================================================
model Review {
  id            String   @id @default(cuid())
  applicationId String
  reviewerId    String
  vote          String   // APPROVE | REJECT | DEFER
  comments      String?
  boostAction   String?  // UP | DOWN | MONITOR | SHUTDOWN
  boostReason   String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  reviewer    User        @relation(fields: [reviewerId], references: [id])
}

// ============================================================
// CONTRACT — Awarded funding agreements
// ============================================================
model Contract {
  id                String   @id @default(cuid())
  applicationId     String   @unique
  programId         String
  organizationId    String
  awardAmount       Float
  justification     String?
  milestoneSchedule String?  // JSON string
  status            String   @default("ACTIVE") // ACTIVE | COMPLETED | SUSPENDED | TERMINATED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  application   Application    @relation(fields: [applicationId], references: [id])
  program       Program        @relation(fields: [programId], references: [id])
  organization  Organization   @relation(fields: [organizationId], references: [id])
  milestones    Milestone[]
  disbursements Disbursement[]
}

// ============================================================
// MILESTONE — Deliverable checkpoints within a Contract
// ============================================================
model Milestone {
  id                  String    @id @default(cuid())
  contractId          String
  sequence            Int
  title               String
  disbursementPct     Float
  disbursementAmount  Float
  triggerDescription  String?
  verificationMethod  String?
  status              String    @default("PENDING") // PENDING | EVIDENCE_SUBMITTED | VERIFIED | FAILED
  verifiedAt          DateTime?
  createdAt           DateTime  @default(now())

  contract        Contract        @relation(fields: [contractId], references: [id])
  evidenceRecords EvidenceRecord[]
  disbursements   Disbursement[]
}

// ============================================================
// EVIDENCE RECORD — Physical verification artifacts
// ============================================================
model EvidenceRecord {
  id              String    @id @default(cuid())
  milestoneId     String
  type            String    // PHOTO | DRONE | SENSOR | REPORT
  filePath        String?
  metadata        String?   // JSON string
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  reviewStatus    String    @default("PENDING") // PENDING | APPROVED | REJECTED
  slideSolveCheck String    @default("PENDING") // PASS | FAIL | PENDING

  milestone Milestone @relation(fields: [milestoneId], references: [id])
}

// ============================================================
// DISBURSEMENT — Payment releases tied to milestones
// ============================================================
model Disbursement {
  id          String    @id @default(cuid())
  contractId  String
  milestoneId String
  amount      Float
  status      String    @default("PENDING") // PENDING | APPROVED | HELD | RELEASED
  approvedBy  String?
  holdReason  String?
  releasedAt  DateTime?
  createdAt   DateTime  @default(now())

  contract  Contract  @relation(fields: [contractId], references: [id])
  milestone Milestone @relation(fields: [milestoneId], references: [id])
}

// ============================================================
// AUDIT EVENT — Tamper-evident log chain for all actions
// ============================================================
model AuditEvent {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  resourceType String
  resourceId   String?
  purpose      String?
  details      String?  // JSON string
  timestamp    DateTime @default(now())
  hashPrev     String?
  hashCurr     String?

  actor User? @relation(fields: [actorId], references: [id])
}

// ============================================================
// BOOST ACTION — Human override of AI scoring decisions
// ============================================================
model BoostAction {
  id              String   @id @default(cuid())
  actorId         String
  targetType      String   // APPLICATION | CONTRACT
  targetId        String
  boostType       String   // UP | DOWN | MONITOR | SHUTDOWN
  reason          String?
  originalAiScore Float?
  timestamp       DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}
